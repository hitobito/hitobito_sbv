- action = entry.persisted? ? :update : :create
- action_path = entry.persisted? ? [@original_group || group, entry] : [group, entry]

= standard_form action_path, controller: :roles, action: action, remote: true  do |f|
  = hidden_field_tag :role_form_context, 'modal'
  = f.error_messages
  - if @group_selection.present? && @group_selection.size > 1
    = f.labeled(:group_id) do
      .shown.ms-0
        = f.select(:group_id,
                   group_options_with_level,
                   { },
                   { class: 'form-select form-select-sm',
                     data: { remote: true,
                             url: role_types_group_roles_path(@group),
                             chosen_no_results: t('global.chosen_no_results') } })
  - else
    = f.hidden_field :group_id

  = f.labeled(:type) do
    #role_type_select.ms-0
      = render "type_select"

  #role_instrument_field
    = render "instrument_field", f: f, entry: entry, group: @group, modal: true

  #role_label_field{ class: ('d-none' if mitglied_role_type?(role_type_class(entry, @group))) }
    = f.labeled(:label) do
      .shown.ms-0
        = f.input_field(:label,
                        help: t('roles.label.help_optional_label'),
                        data: { provide: :typeahead, source: entry.klass.available_labels })

  - if @person_id
    = f.hidden_field :person_id, value: @person_id

  = f.hidden_field :start_on, value: entry.start_on
  = f.hidden_field :end_on, value: entry.end_on
  = form_buttons(f, submit_label: ti(:"button.save"), cancel_url: '#')
